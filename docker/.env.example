# Copy on the server: cp .env.example .env
#
# Site is built and served inside Docker — nothing required on your laptop.
#
# Local access on the server:
#   curl http://127.0.0.1:8450/
#
# Remote access via SSH tunnel (does not touch host nginx on 80/443):
#   ssh -L 8450:127.0.0.1:8450 user@your-server
#   open http://127.0.0.1:8450/
#
# Or bind on all interfaces (still only port 8450):
# PAGES_BIND=0.0.0.0

PAGES_BIND=127.0.0.1
PAGES_PORT=8450

# make = full build + auto-update (default)
# dev  = faster dev mode
# serve = no file watchers
MODE=make
