# Copy to .env and adjust: cp .env.example .env
#
# Bind only on localhost (default) — safest; use SSH tunnel for remote access:
#   ssh -L 8450:127.0.0.1:8450 user@your-server
# Then open http://127.0.0.1:8450/
#
# Or bind on all interfaces (still port 8450 only — does not touch host 80/443):
# PAGES_BIND=0.0.0.0

PAGES_BIND=127.0.0.1
PAGES_HOST_PORT=8450
PAGES_DEV_PORT=8451
PAGES_SITE_DIR=./site

# dev service only: dev | serve | make
MODE=dev
